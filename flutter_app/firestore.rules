rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isDisabledUser(userId) {
      return exists(userDocPath(userId))
        && get(userDocPath(userId)).data.keys().hasAny(['accountStatus'])
        && get(userDocPath(userId)).data.accountStatus == 'disabled';
    }

    function isActiveOwner(userId) {
      return isOwner(userId) && !isDisabledUser(userId);
    }

    function currentUserProfile() {
      return isSignedIn()
        && exists(userDocPath(request.auth.uid))
        ? get(userDocPath(request.auth.uid)).data.profile
        : null;
    }

    function isCoachProfile() {
      return currentUserProfile() in [
        'coach',
        'intern',
        'athleteCoach',
        'athleteIntern',
        'admin'
      ];
    }

    function isPublishedExercise(data) {
      return !data.keys().hasAny(['status'])
        || data.status in ['publicado', 'processado'];
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId);
      allow update: if isActiveOwner(userId);

      match /results/{resultId} {
        allow read, write: if isActiveOwner(userId);
      }

      match /stats/{document} {
        allow read, write: if isActiveOwner(userId);
      }

      match /profiles/{profileId} {
        allow read, write: if isActiveOwner(userId);
      }

      match /prs/{prId} {
        allow read, write: if isActiveOwner(userId);
      }

      match /weekly_load/{weekLabel} {
        allow read, write: if isActiveOwner(userId);
      }

      match /insights/{document=**} {
        allow read, write: if isActiveOwner(userId);
      }

      // Configuracoes reais de privacidade.
      match /settings/{settingId} {
        allow read: if isOwner(userId)
          && settingId == 'privacy';

        allow create, update: if isActiveOwner(userId)
          && settingId == 'privacy';

        allow delete: if false;
      }
    }

    match /exercises/{document=**} {
      allow read: if isSignedIn()
        && (isCoachProfile() || isPublishedExercise(resource.data));
      allow create, update, delete: if isCoachProfile();
    }

    match /cycles/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /movimentos/{document} {
      allow read: if isSignedIn();
    }

    match /cohorts/{document=**} {
      allow read, write: if false;
    }

    match /telemetry/{document=**} {
      allow read, write: if false;
    }
  }
}
